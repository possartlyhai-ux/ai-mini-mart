# Copy to .env for local dev. In production (Render) these are set in the
# dashboard / render.yaml, NOT committed.

# Postgres connection string (Prisma reads DATABASE_URL).
# Local dev: run a Postgres and point this at it, e.g. via Docker:
#   docker run --name aimm-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=ai_mini_mart -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_mini_mart"

# Secret used to sign the auth JWT cookie. MUST be a long random value in prod.
JWT_SECRET="dev-secret-change-me"

# Comma-separated storefront origins allowed to call the public feed (CORS).
# localhost:5173 is always allowed. In prod set this to the storefront URL(s),
# e.g. https://ai-mini-mart.web.app,https://ai-mini-mart.firebaseapp.com
CORS_ORIGIN=""

# Port the admin app + API listen on (Render sets PORT automatically).
PORT=3000
