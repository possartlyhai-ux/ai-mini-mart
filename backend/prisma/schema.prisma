// Ai Mini-Mart — staff/POS backend schema.
//
// DB is SQLite for zero-setup local dev. To move to Postgres later, change the
// datasource `provider` to "postgresql" and point DATABASE_URL at the server —
// no model changes are required (enums are modelled as documented String fields
// precisely so SQLite and Postgres share one schema).
//
// MONEY: every *Minor field is an INTEGER in THB minor units (satang = baht*100)
// for decimal-safe arithmetic. Convert/format via src/lib/currency.js.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  username     String   @unique
  passwordHash String
  role         String   @default("STAFF") // "OWNER" | "STAFF"
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bills Bill[]
}

// A product is a grouping; its sellable SKUs are its Variants. Shared fields
// (unit/categories/visibility) live here; price/barcode/image/stock live on the
// Variant. Every product has at least one variant.
model Product {
  id        Int      @id @default(autoincrement())
  name      String // "Item Name"
  sku       String?  @unique // stable storefront id (auto-assigned: MM-###)
  unit      String? // "Type" — e.g. "Unit", "250 g", "1 pair"
  tagsJson  String   @default("[]") // JSON: ["electronics", ...] (category slugs)
  sortOrder Int      @default(0) // storefront display order; ascending = top of store
  isVisible Boolean  @default(true) // "Show in store" toggle -> storefront feed
  isActive  Boolean  @default(true) // soft delete / retire
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants  Variant[]
  billItems BillItem[]
}

// A sellable SKU. Carries its own price (THB + storefront KHR), barcode, image,
// and in-stock switch. Scanned/sold individually in the POS.
model Variant {
  id             Int      @id @default(autoincrement())
  productId      Int
  name           String // "Variant Name" — e.g. "Big", "Small"
  barcode        String?  @unique
  imageUrl       String?
  sellPriceMinor Int      @default(0) // THB price (satang) — the POS billing base
  sellPriceKhr   Int      @default(0) // storefront KHR price (whole riel; KHR has 0 decimals)
  inStock        Boolean  @default(true) // availability switch
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  billItems BillItem[]

  @@index([productId])
}

// Editable storefront categories. Products reference these by `slug` in tagsJson.
model Category {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  label     String
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bill {
  id            Int      @id @default(autoincrement())
  billNo        String   @unique // e.g. "B-00001"
  subtotalMinor Int
  totalMinor    Int
  currency      String   @default("THB") // display currency chosen at sale time
  paymentMethod String   @default("CASH") // "CASH" | "OTHER"
  customerName  String?
  status        String   @default("PAID") // "PAID" | "VOID"
  staffId       Int
  createdAt     DateTime @default(now())

  staff User       @relation(fields: [staffId], references: [id])
  items BillItem[]

  @@index([createdAt])
  @@index([staffId])
}

model BillItem {
  id             Int    @id @default(autoincrement())
  billId         Int
  productId      Int? // nullable so history survives product deletion
  variantId      Int? // nullable so history survives variant deletion
  nameSnapshot   String // "Product — Variant" at sale time
  qty            Int
  unitPriceMinor Int
  lineTotalMinor Int

  bill    Bill     @relation(fields: [billId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([productId])
}

model PrinterSetting {
  id         Int      @id @default(autoincrement())
  name       String
  paperWidth String   @default("80mm") // "58mm" | "80mm" | "A4"
  type       String   @default("thermal") // "thermal" | "normal"
  headerText String?
  footerText String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
